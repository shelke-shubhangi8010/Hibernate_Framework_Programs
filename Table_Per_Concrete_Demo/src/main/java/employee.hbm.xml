<?xml version="1.0" encoding="UTF-8"?>

<hibernate-mapping>
    <class name="test.Employee" table="Emp123">
        <id name="id" column="eid">
            <generator class="increment"/>
        </id>


        <property name="name" column="Name"/>

        <union-subclass name="test.Regular_Employee" table="reg123">
            <property name="salary" column="salary"/>
            <property name="bonus" column="Bonus"/>
        </union-subclass>

        <union-subclass name="test.Contract_Employee" table="Con123">
            <property name="pay_per_hour" column="pay_per_hour"/>
            <property name="contract_period" column="contract_period"/>
        </union-subclass>
    </class>
</hibernate-mapping>


